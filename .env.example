# ============================================================
# TV Stack — Environment Configuration
#
# 1. Copy this file:  cp .env.example .env
# 2. Fill in your Surfshark WireGuard private key
# 3. Run: docker compose up -d
# ============================================================

# ============================================================
# SYSTEM SETTINGS
# ============================================================

# Your timezone (list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/New_York

# Your Linux user/group ID. Find yours with: id
PUID=1000
PGID=1000

# Path to your media root on the host.
# This mounts as /data inside every container:
#   /data/TV        → $MEDIA_BASE/TV        (Sonarr root folder)
#   /data/Movies    → $MEDIA_BASE/Movies    (Radarr root folder)
#   /data/Music     → $MEDIA_BASE/Music     (Lidarr root folder)
#   /data/Downloads → $MEDIA_BASE/Downloads (qBittorrent download dir)
MEDIA_BASE=/mnt/e/Media

# ============================================================
# VPN SETTINGS — Surfshark OpenVPN (TCP)
# Credentials at: https://my.surfshark.com/vpn/manual-setup/main
# Select the OpenVPN tab → copy service username and password
# NOTE: These are NOT your Surfshark login email/password
#
# WireGuard does NOT work in WSL2 — UDP port 51820 is blocked
# by Windows Firewall at the WSL2 virtual switch level.
# OpenVPN over TCP (port 443) works reliably.
# ============================================================

VPN_SERVICE_PROVIDER=surfshark
VPN_TYPE=openvpn

OPENVPN_USER=
OPENVPN_PASSWORD=

# WireGuard (non-functional in WSL2 — kept for reference):
WIREGUARD_PRIVATE_KEY=
WIREGUARD_ADDRESSES=10.14.0.2/16
WIREGUARD_PUBLIC_KEY=
WIREGUARD_PRESHARED_KEY=

SERVER_COUNTRIES=United States

# Port forwarding — not supported by Surfshark, leave blank:
VPN_PORT_FORWARDING=
FIREWALL_VPN_INPUT_PORTS=

# ============================================================
# NETWORK — Static IPs for each service
# You shouldn't need to change these unless you have a conflict.
# ============================================================
IP_GLUETUN=172.39.0.2
IP_RADARR=172.39.0.3
IP_SONARR=172.39.0.4
IP_LIDARR=172.39.0.5
IP_BAZARR=172.39.0.6
IP_SEERR=172.39.0.8
IP_HOMEPAGE=172.39.0.9

# Tailscale auth key — get from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
